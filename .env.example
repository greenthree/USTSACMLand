# Public browser configuration. These values are embedded in the Vite bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Read-only post-deployment ranking audit. Usually supplied by GitHub Pages.
PRODUCTION_E2E_BASE_URL=https://greenthree.github.io/USTSACMLand/

# Server-side deployment and scheduled-sync configuration. Never expose these
# variables through VITE_* names or commit their real values.
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated browser origins, without path components.
ALLOWED_ORIGIN=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
QOJ_SERVICE_USERNAME=
QOJ_SERVICE_PASSWORD=
LUOGU_COOKIE=
LUOGU_CSRF_TOKEN=
SYNC_ALERT_WEBHOOK_URL=
SYNC_ALERT_WEBHOOK_TOKEN=
# Fine-grained GitHub token: only Variables (write) on the target repository.
DELETION_RECOVERY_REPOSITORY=greenthree/USTSACMLand
DELETION_RECOVERY_GITHUB_TOKEN=

# Optional adapter tuning.
CODEFORCES_MAX_PAGES=100
LUOGU_MAX_PAGES=100
XCPC_ELO_DATA_URL=

# Public browser configuration. These values are embedded in the Vite bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Hidden until the relay compatibility review and production release checklist pass.
VITE_WEBCHAT_UI_ENABLED=false
# Optional local-test override. Production may only use the current Supabase
# project's /functions/v1/webchat endpoint; never include a key in this URL.
VITE_WEBCHAT_API_URL=

# Read-only post-deployment ranking audit. Usually supplied by GitHub Pages.
PRODUCTION_E2E_BASE_URL=https://greenthree.github.io/USTSACMLand/

# Server-side deployment and scheduled-sync configuration. Never expose these
# variables through VITE_* names or commit their real values.
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated browser origins, without path components.
ALLOWED_ORIGIN=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
QOJ_SERVICE_USERNAME=
QOJ_SERVICE_PASSWORD=
LUOGU_COOKIE=
LUOGU_CSRF_TOKEN=
# Optional shared operational webhook for sync, Firecrawl, runtime, and WebChat budget alerts.
SYNC_ALERT_WEBHOOK_URL=
SYNC_ALERT_WEBHOOK_TOKEN=
# Fine-grained GitHub token: only Variables (write) on the target repository.
DELETION_RECOVERY_REPOSITORY=greenthree/USTSACMLand
DELETION_RECOVERY_GITHUB_TOKEN=

# WebChat remains unavailable unless this server-side switch is explicitly true.
CHAT_ENABLED=false
CHAT_ALLOWED_ORIGINS=https://greenthree.github.io,http://localhost:5173,http://127.0.0.1:5173
# Bootstrap/emergency fallback only, used when the database migration has not
# produced a configuration row. Any existing database row is authoritative.
CHAT_RELAY_BASE_URL=
CHAT_RELAY_API_KEY=
CHAT_RELAY_MODEL=gpt-5.6
CHAT_SYSTEM_PROMPT_VERSION=usts-learning-assistant-v1
CHAT_MAX_REQUEST_BYTES=262144
CHAT_MAX_MESSAGES=40
CHAT_MAX_MESSAGE_CHARS=12000
CHAT_MAX_TOTAL_CHARS=60000
CHAT_MAX_OUTPUT_TOKENS=2048
CHAT_REQUEST_TIMEOUT_MS=120000
# System minute guard and request lease. Daily member limits are configured in
# the administrator member detail page and have no environment fallback.
CHAT_REQUESTS_PER_MINUTE=3
CHAT_CLAIM_LEASE_SECONDS=180
# Bootstrap fallback for the all-member daily budget. Once the database
# configuration row exists, /admin/webchat values take precedence even while paused.
CHAT_GLOBAL_REQUESTS_PER_DAY=300
CHAT_GLOBAL_TOKENS_PER_DAY=1000000
# Manual relay compatibility checker. Its report is sanitized and generated locally.
WEBCHAT_RELAY_TIMEOUT_MS=120000
WEBCHAT_RELAY_ABORT_SETTLE_MS=2000
WEBCHAT_RELAY_ABORT_CHECK=true
WEBCHAT_RELAY_REPORT_PATH=artifacts/webchat-relay-compatibility.json

# Optional adapter tuning.
CODEFORCES_MAX_PAGES=100
LUOGU_MAX_PAGES=100
XCPC_ELO_DATA_URL=
